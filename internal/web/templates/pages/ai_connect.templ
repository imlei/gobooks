// 遵循产品需求 v1.0
package pages

import "gobooks/internal/models"
import "gobooks/internal/web/templates/layout"
import "gobooks/internal/web/templates/ui"

templ AIConnect(vm AIConnectVM) {
	@layout.Layout(
		"GoBooks - AI Connect",
		ui.SidebarVM{Active: "AI Connect Settings", HasCompany: vm.HasCompany},
		bodyAIConnect(vm),
	)
}

templ bodyAIConnect(vm AIConnectVM) {
	<div class="max-w-[95%]">
		<h1 class="text-title font-semibold">AI Connect</h1>
		<p class="mt-2 text-text-muted2 max-w-3xl">
			Configure how GoBooks connects to external AI services. This is the foundation for future features such as
			receipt scanning, invoice extraction, and document understanding. No document processing runs from this page yet—only
			connection settings are stored here.
		</p>

		if vm.Saved {
			<div class="mt-4 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
				Settings saved.
			</div>
		}
		if vm.Tested {
			<div class="mt-4 rounded-md border border-border bg-background p-4 text-body text-text">
				Connection test completed. See status below.
			</div>
		}
		if vm.FormError != "" {
			<div class="mt-4 rounded-md border border-border-danger bg-danger-soft p-4 text-body text-danger-hover">
				{ vm.FormError }
			</div>
		}

		<form method="post" action="/settings/ai-connect" class="mt-6 space-y-6">
			<div class="rounded-lg border border-border bg-surface p-6">
				<div class="border-b border-border bg-background -mx-6 -mt-6 px-6 py-3 mb-6">
					<div class="text-small font-semibold uppercase tracking-wider text-text-muted">AI service connection</div>
					<p class="mt-1 text-small text-text-muted2">
						Provider credentials are stored on the server only. The browser never receives your full API key after save.
					</p>
				</div>

				<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
					<div>
						<label class="block text-body font-medium text-text">Provider *</label>
						<select
							name="provider"
							class="mt-2 block w-full rounded-md border border-border-input bg-surface px-3 py-2 text-body outline-none focus:ring-2 focus:ring-primary-focus"
						>
							<option value={ models.AIProviderOpenAICompatible } selected?={ vm.Provider == models.AIProviderOpenAICompatible }>OpenAI-compatible</option>
							<option value={ models.AIProviderCustomEndpoint } selected?={ vm.Provider == models.AIProviderCustomEndpoint }>Custom endpoint</option>
						</select>
						<p class="mt-1 text-small text-text-muted">Extensible for additional providers later.</p>
					</div>

					@textField("API Base URL *", "api_base_url", vm.APIBaseURL, "", "https://api.example.com/v1")

					<div class="md:col-span-2">
						@ui.InputField("API Key", "api_key", "", "Enter a new key to replace the stored key", "password", "")
						if vm.HasAPIKey {
							<p class="mt-2 text-small text-text-muted">
								Saved key: <span class="font-mono text-text">{ vm.APIKeyHint }</span>
							</p>
						}
					</div>

					@textField("Model Name", "model_name", vm.ModelName, "", "e.g. gpt-4o-mini")

					<div class="flex flex-wrap items-center gap-6 md:col-span-2">
						<label class="inline-flex items-center gap-2 cursor-pointer select-none">
							<input
								type="checkbox"
								name="enabled"
								value="true"
								checked?={ vm.Enabled }
								class="h-4 w-4 rounded border-border-input text-primary focus:ring-primary-focus"
							/>
							<span class="text-body text-text">Enabled</span>
						</label>
						<label class="inline-flex items-center gap-2 cursor-pointer select-none">
							<input
								type="checkbox"
								name="vision_enabled"
								value="true"
								checked?={ vm.VisionEnabled }
								class="h-4 w-4 rounded border-border-input text-primary focus:ring-primary-focus"
							/>
							<span class="text-body text-text">Vision enabled</span>
						</label>
					</div>
				</div>
			</div>

			<div class="flex flex-wrap items-center justify-between gap-4">
				<p class="text-small text-text-muted max-w-xl">
					Test Connection uses the last saved configuration—save first if you changed fields above.
				</p>
				@ui.ButtonPrimary("Save", "submit", false)
			</div>
		</form>

		<form method="post" action="/settings/ai-connect/test" class="mt-4 flex flex-wrap items-center gap-4">
			@ui.ButtonSecondary("Test Connection", "submit", false)
			<span class="text-small text-text-muted">Runs a server-side reachability check (no keys sent to the browser).</span>
		</form>

		if vm.HasLastTest {
			<div class="mt-6 rounded-lg border border-border bg-surface p-6">
				<h2 class="text-section font-semibold text-text">Connection status</h2>
				<p class="mt-2 text-small text-text-muted">
					Last test: { vm.LastTestAtFormatted }
				</p>
				if vm.LastTestOK {
					<div class="mt-3 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
						{ vm.LastTestMessage }
					</div>
				} else {
					<div class="mt-3 rounded-md border border-border-danger bg-danger-soft p-4 text-body text-danger-hover">
						{ vm.LastTestMessage }
					</div>
				}
			</div>
		}

		<div class="mt-6 rounded-lg border border-border bg-background p-4 text-small text-text-muted max-w-3xl">
			<span class="font-medium text-text">Security:</span>
			API keys are stored only on the server and are never written to the browser localStorage, audit log details, or
			third-party scripts from this page. After saving, the full key is not shown again—only a masked hint.
		</div>
	</div>
}
