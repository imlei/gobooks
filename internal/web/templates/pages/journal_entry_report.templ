// 遵循project_guide.md
package pages

import "gobooks/internal/web/templates/layout"
import "gobooks/internal/web/templates/ui"

templ JournalEntryReport(vm JournalEntryReportVM) {
	@layout.Layout(
		"GoBooks - Journal Entries Report",
		ui.SidebarVM{Active: "Reports", HasCompany: vm.HasCompany},
		bodyJournalEntryReport(vm),
	)
}

templ bodyJournalEntryReport(vm JournalEntryReportVM) {
	<div class="max-w-[95%]">
		<h1 class="text-title font-semibold">Reports</h1>
		<p class="mt-2 text-text-muted2">Journal Entries</p>

		@ReportsNav(vm.ActiveTab)

		if vm.FormError != "" {
			<div class="mt-4 rounded-md border border-border-danger bg-danger-soft p-4 text-body text-danger-hover">
				{ vm.FormError }
			</div>
		}

		<form method="get" action="/reports/journal-entries" class="mt-6 rounded-lg border border-border bg-surface p-6">
			<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
				<div>
					<label class="block text-body font-medium text-text">From</label>
					<input type="date" name="from" value={ vm.From }
						class="mt-2 block w-full rounded-md border border-border-input px-3 py-2 text-body outline-none focus:ring-2 focus:ring-primary-focus"/>
				</div>
				<div>
					<label class="block text-body font-medium text-text">To</label>
					<input type="date" name="to" value={ vm.To }
						class="mt-2 block w-full rounded-md border border-border-input px-3 py-2 text-body outline-none focus:ring-2 focus:ring-primary-focus"/>
				</div>
				<div class="flex items-end justify-end">
					<button type="submit" class="rounded-md bg-primary px-4 py-2 text-body font-semibold text-onPrimary hover:bg-primary-hover">
						Run Report
					</button>
				</div>
			</div>
		</form>

		<div class="mt-6 space-y-8">
			if len(vm.Entries) == 0 {
				<div class="rounded-lg border border-border bg-surface p-6 text-body text-text-muted2">
					No journal entries in this date range.
				</div>
			} else {
				for _, e := range vm.Entries {
					<div class="rounded-lg border border-border bg-surface p-6">
						<div class="flex flex-wrap items-baseline justify-between gap-2 border-b border-border pb-4">
							<div>
								<span class="text-section font-semibold text-text">{ e.EntryDate }</span>
								if e.JournalNo != "" {
									<span class="ml-3 font-mono text-body text-text-muted">{ e.JournalNo }</span>
								}
								<span class="ml-3 text-small text-text-muted">#{ e.ID }</span>
							</div>
							if e.ReversalNote != "" {
								<span class="text-small font-medium text-text-muted2">{ e.ReversalNote }</span>
							}
						</div>
						<div class="mt-4 overflow-x-auto">
							<table class="w-full text-left text-body">
								<thead class="text-small uppercase tracking-wider text-text-muted">
									<tr class="border-b border-border">
										<th class="py-3 pr-4">Account</th>
										<th class="py-3 pr-4">Memo</th>
										<th class="py-3 pr-4 text-right">Debit</th>
										<th class="py-3 pr-0 text-right">Credit</th>
									</tr>
								</thead>
								<tbody class="text-text">
									for _, line := range e.Lines {
										<tr class="border-b border-border-subtle">
											<td class="py-3 pr-4">
												<span class="font-mono font-medium">{ line.AccountCode }</span>
												<span class="text-text-muted2"> — </span>
												{ line.AccountName }
											</td>
											<td class="py-3 pr-4 text-text-muted2">{ line.Memo }</td>
											<td class="py-3 pr-4 text-right">{ Money(line.Debit) }</td>
											<td class="py-3 pr-0 text-right">{ Money(line.Credit) }</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				}
			}
		</div>
	</div>
}
